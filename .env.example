# ========================================
# ODA BlocksKids - .env.example
# ========================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha as configurações de acordo com seu ambiente
# 3. NÃO commite o arquivo .env para o Git
#
# ========================================

# ========== SERVIDOR EXPRESS ==========
# Porta do servidor backend (padrão: 5000)
PORT=5000

# Ambiente de execução: development, production, test (padrão: development)
NODE_ENV=development

# ========== BANCO DE DADOS ==========
# PostgreSQL Connection String
# Neon: postgresql://user:password@ep-.neon.tech/dbname
# Supabase: postgresql://postgres:password@host.supabase.co:5432/postgres
# Local: postgresql://user:password@localhost:5432/oda_blockskids
DATABASE_URL=postgresql://user:password@localhost:5432/oda_blockskids

# ========== ARDUINO CLI ==========
# Versão do Arduino CLI (obrigatório para compilação)
# Versão recomendada: 0.34.0 ou superior
ARDUINO_CLI_VERSION=0.34.0

# Caminho para Arduino CLI (deixe vazio se instalado globalmente)
# macOS/Linux: /usr/local/bin/arduino-cli ou /home/user/arduino-cli/arduino-cli
# Windows: C:\\Program Files\\Arduino\\arduino-cli.exe
ARDUINO_CLI_PATH=

# ========== FIREBASE (Opcional - para autenticação) ==========
# Obtenha credenciais em: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ========== API E FRONTEND ==========
# URL que o frontend usa para chamar a API
# Desenvolvimento local
VITE_API_URL=http://localhost:5000

# Produção (exemplos - descomente o apropriado)
# Railway: https://seu-projeto-railway.up.railway.app
# VITE_API_URL=https://seu-projeto-railway.up.railway.app

# Render: https://seja-api.onrender.com
# VITE_API_URL=https://seu-projeto.onrender.com

# VPS Custom: seu-dominio.com
# VITE_API_URL=https://seu-dominio.com

# ⚠️ Vercel NÃO funciona com Arduino CLI (sem suporte a executáveis nativos)
# VITE_API_URL=https://seu-projeto.vercel.app

# ========== SESSÃO ==========
# Secret para criptografia de sessão
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_a_random_secret_key_here

# Duração máxima da sessão em milissegundos (padrão: 24 horas)
SESSION_MAX_AGE=86400000

# ========== DEPLOY ==========
# ID do Replit (preenchido automaticamente no Replit)
REPL_ID=

# ========== CORS ==========
# Origens permitidas para CORS (separadas por vírgula, sem espaços)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Produção (exemplo)
# CORS_ORIGIN=https://seu-dominio.com,https://app.seu-dominio.com
# Azure (exemplo)
# CORS_ORIGIN=https://seu-app.azurestaticapps.net,https://seu-backend.azurewebsites.net

# ========== FEATURES ==========
# Habilitar modo offline (experimental)
VITE_OFFLINE_MODE=false

# Habilitar depuração de comunicação serial
DEBUG_SERIAL=false

# Habilitar extensão Chrome para upload
ENABLE_CHROME_EXTENSION=true

# Permitir HEX de teste quando nenhum compilador real estiver disponível
# Em produção, mantenha false para não mascarar erro de compilação
ALLOW_MOCK_HEX_FALLBACK=false

# ========== LOGS ==========
# Nível de log: error, warn, info, debug (padrão: info)
LOG_LEVEL=info

# Arquivo de log (deixe em branco para apenas console)
LOG_FILE=logs/app.log
