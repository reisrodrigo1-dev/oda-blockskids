# Arquivo de exemplo para configuração de ambiente
# Copie este arquivo para .env e configure conforme necessário

# URL da API de compilação Arduino
# Para desenvolvimento local (servidor rodando na porta 5000)
VITE_API_URL=http://localhost:5000

# Para produção no Railway
# VITE_API_URL=https://seu-app-arduino.up.railway.app

# Para produção no Render
# VITE_API_URL=https://seu-app-arduino.onrender.com

# Para produção no VPS
# VITE_API_URL=https://seu-dominio.com

# NOTA: Não use Vercel para a API pois não suporta Arduino CLI
# VITE_API_URL=https://oda-blockskids.vercel.app  # NÃO FUNCIONA